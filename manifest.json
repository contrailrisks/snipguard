{
  "manifest_version": 3,
  "name": "SnipGuard \u2014 paste protection for AI prompts",
  "short_name": "SnipGuard",
  "version": "0.1.0",
  "description": "On-device detector that warns or blocks when you paste API keys, PII, or proprietary code into ChatGPT and other AI tools.",
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "sw.js"
  },
  "action": {
    "default_title": "SnipGuard",
    "default_popup": "options.html"
  },
"browser_specific_settings": {
  "gecko": {
    "id": "snipguard@contrailrisks",
    "strict_min_version": "121.0"
  }
},
"content_scripts": [{
  "matches": ["https://*/*", "http://*/*"],
  "js": [
    "lib/browser-polyfill.min.js",
    "src/detectors/types.js",
    "src/detectors/core.js",
    "src/detectors/secrets/openai.js",
    "src/detectors/secrets/github.js",
    "src/detectors/secrets/aws.js",
    "src/detectors/secrets/stripe.js",
    "src/detectors/secrets/azure.js",
    "src/detectors/secrets/azure-sql.js",
    "src/detectors/secrets/azure-client-secret.js",
    "src/detectors/secrets/discord.js",
    "src/detectors/secrets/firebase.js",
    "src/detectors/secrets/google-oauth.js",
    "src/detectors/secrets/cloudflare.js",
    "src/detectors/secrets/postgres.js",
    "src/detectors/secrets/pem.js",
    "src/detectors/secrets/anthropic.js",
    "src/detectors/secrets/huggingface.js",
    "src/detectors/secrets/slack.js",
    "src/detectors/secrets/twilio.js",
    "src/detectors/secrets/telegram.js",
    "src/detectors/secrets/npm-token.js",
    "src/detectors/secrets/sendgrid.js",
    "src/detectors/pii/email.js",
    "src/detectors/pii/phone.js",
    "src/detectors/pii/credit-card.js",
    "src/detectors/pii/iban.js",
    "src/detectors/code/heuristic.js",
    "src/detectors/code/org-markers.js",
    "src/detectors/secrets/high-entropy.js",
    "src/detectors/index.js",
    "src/ui.js",
    "src/content.js"
  ],
  "css": ["src/ui.css"],
  "run_at": "document_start"
}],
  "options_page": "options.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}